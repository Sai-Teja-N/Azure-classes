# ──────────── LLM PROVIDER (choose one) ────────────
# Supported: bedrock | azure
LLM_PROVIDER=bedrock
LLM_MODEL=amazon.nova-micro-v1:0
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=1024

# ──────────── AWS Bedrock ────────────
# Credentials: supply key+secret, or set AWS_PROFILE, or rely on instance role.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
AWS_DEFAULT_REGION=us-east-1
AWS_PROFILE=rca-bedrock
# Optional overrides (model ID can also be set via LLM_MODEL above):
# BEDROCK_INFERENCE_PROFILE_ID=
# BEDROCK_INFERENCE_PROFILE_ARN=
# BEDROCK_MODEL_ID=

# ──────────── Azure OpenAI ────────────
# Fill these if using LLM_PROVIDER=azure
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT_NAME=
AZURE_OPENAI_API_VERSION=2024-02-15-preview



# ──────────── SumoLogic ────────────
SUMO_ACCESS_ID=
SUMO_ACCESS_KEY=
SUMO_ENDPOINT=https://api.sumologic.com/api/v1
# Set to false to read logs from SUMO_LOCAL_FILE_PATH instead of calling the API
SUMOLOGIC_ENABLED=true
SUMO_LOCAL_FILE_PATH=

# ──────────── Slack ────────────
SLACK_BOT_TOKEN=
SLACK_CHANNEL=#incidents
# true = don't actually post, just log what would be sent
SLACK_DRY_RUN=true

# ──────────── PagerDuty ────────────
PD_WEBHOOK_SECRET=

# ──────────── Redis / cache ────────────
REDIS_URL=redis://redis:6379/0
USE_REDIS=false            # false = pure in-memory (no redis container needed)
CACHE_TTL=900

# ──────────── Logging ────────────
LOG_LEVEL=INFO
LOG_DIR=./logs
LOG_FILE=rca.log
