    },
    {
      "name": "PD webhook — flattened payload (legacy format)",
      "request": {
        "method": "POST",
        "header": [ { "key": "Content-Type", "value": "application/json" } ],
        "url": {
          "raw": "{{base_url}}/webhooks/pagerduty",
          "host": ["{{base_url}}"],
          "path": ["webhooks", "pagerduty"]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"incident\": {\n    \"id\": \"P-LEGACY-999\",\n    \"title\": \"Legacy format payload test\",\n    \"urgency\": \"high\",\n    \"service_name\": \"checkout-api\"\n  }\n}"
        }
      }
    },
    {
      "name": "PD webhook — Kubernetes OOM with description",
      "request": {
        "method": "POST",
        "header": [ { "key": "Content-Type", "value": "application/json" } ],
        "url": {
          "raw": "{{base_url}}/webhooks/pagerduty",
          "host": ["{{base_url}}"],
          "path": ["webhooks", "pagerduty"]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"event\": {\n    \"event_type\": \"incident.triggered\",\n    \"resource_type\": \"incident\",\n    \"occurred_at\": \"2026-04-12T14:02:10Z\",\n    \"data\": {\n      \"id\": \"kubernetes-outofmemory-01\",\n      \"type\": \"incident\",\n      \"title\": \"Kubernetes pods down with out of memory\",\n      \"urgency\": \"high\",\n      \"status\": \"triggered\",\n      \"created_at\": \"2026-04-12T14:02:10Z\",\n      \"description\": \"Container checkout-api in namespace default was OOMKilled. Node memory usage is at 99%. Please check the deployment limits.\",\n      \"service\": { \"summary\": \"test\" },\n      \"priority\": { \"summary\": \"P1\" },\n      \"html_url\": \"https://example.pagerduty.com/incidents/P-CHECKOUT-001\"\n    }\n  }\n}"
        }
      }
    }
  ]
}
