{
  "info": {
    "name": "RCA LangGraph - PagerDuty Dummy Tests",
    "description": "Fires dummy PagerDuty incident webhooks at the RCA service. Set {{base_url}} in the environment (default http://localhost:8080). Works end-to-end in dry-run mode (SLACK_DRY_RUN=true) without any external credentials.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:8080" }
  ],
  "item": [
    {
      "name": "Health check",
      "request": {
        "method": "GET",
        "url": { "raw": "{{base_url}}/healthz", "host": ["{{base_url}}"], "path": ["healthz"] }
      }
    },
    {
      "name": "PD webhook — checkout-api 5xx spike (high)",
      "request": {
        "method": "POST",
        "header": [ { "key": "Content-Type", "value": "application/json" } ],
        "url": {
          "raw": "{{base_url}}/webhooks/pagerduty",
          "host": ["{{base_url}}"],
          "path": ["webhooks", "pagerduty"]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"event\": {\n    \"event_type\": \"incident.triggered\",\n    \"resource_type\": \"incident\",\n    \"occurred_at\": \"2026-04-12T14:02:10Z\",\n    \"data\": {\n      \"id\": \"P-CHECKOUT-001\",\n      \"type\": \"incident\",\n      \"title\": \"Checkout API 5xx spike — error rate 12%\",\n      \"urgency\": \"high\",\n      \"status\": \"triggered\",\n      \"created_at\": \"2026-04-12T14:02:10Z\",\n      \"service\": { \"id\": \"PSVC001\", \"summary\": \"checkout-api\" },\n      \"priority\": { \"summary\": \"P1\" },\n      \"html_url\": \"https://example.pagerduty.com/incidents/P-CHECKOUT-001\"\n    }\n  }\n}"
        }
      }
    },
    {
      "name": "PD webhook — payments-svc timeout (high)",
      "request": {
        "method": "POST",
        "header": [ { "key": "Content-Type", "value": "application/json" } ],
        "url": {
          "raw": "{{base_url}}/webhooks/pagerduty",
          "host": ["{{base_url}}"],
          "path": ["webhooks", "pagerduty"]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"event\": {\n    \"event_type\": \"incident.triggered\",\n    \"data\": {\n      \"id\": \"P-PAYMENTS-007\",\n      \"title\": \"payments-svc p99 latency > 5s\",\n      \"urgency\": \"high\",\n      \"created_at\": \"2026-04-12T14:05:00Z\",\n      \"service\": { \"summary\": \"payments-svc\" }\n    }\n  }\n}"
        }
      }
    },
    {
      "name": "PD webhook — auth-gateway degradation (low)",
      "request": {
        "method": "POST",
        "header": [ { "key": "Content-Type", "value": "application/json" } ],
        "url": {
          "raw": "{{base_url}}/webhooks/pagerduty",
          "host": ["{{base_url}}"],
          "path": ["webhooks", "pagerduty"]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"event\": {\n    \"data\": {\n      \"id\": \"P-AUTH-042\",\n      \"title\": \"auth-gateway degraded — 2% 401s\",\n      \"urgency\": \"low\",\n      \"created_at\": \"2026-04-12T14:10:00Z\",\n      \"service\": { \"summary\": \"auth-gateway\" }\n    }\n  }\n}"
        }
      }
    },
    {
      "name": "PD webhook — orders-db connection errors",
      "request": {
        "method": "POST",
        "header": [ { "key": "Content-Type", "value": "application/json" } ],
        "url": {
          "raw": "{{base_url}}/webhooks/pagerduty",
          "host": ["{{base_url}}"],
          "path": ["webhooks", "pagerduty"]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"event\": {\n    \"data\": {\n      \"id\": \"P-DB-013\",\n      \"title\": \"orders-db connection errors\",\n      \"urgency\": \"high\",\n      \"created_at\": \"2026-04-12T14:12:00Z\",\n      \"service\": { \"summary\": \"orders-db\" }\n    }\n  }\n}"
        }
